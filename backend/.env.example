# Database — defaults to local SQLite if unset. For deployment use Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email alerts (SMTP) — leave unset to just log alerts to console for demo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# WhatsApp alerts via Twilio sandbox — leave unset to just log alerts to console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Optional: path to a trained TAT model (falls back to heuristic if absent)
TAT_MODEL_PATH=app/services/tat_model.joblib
